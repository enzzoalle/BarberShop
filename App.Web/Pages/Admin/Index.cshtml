@page "/admin"
@model App.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Painel administrativo";
}

<section class="admin-container">
    <div id="adminLoginCard" class="admin-auth-card glass-card">
        <h1 class="mb-3">Acesso administrativo</h1>
        <p class="text-muted">Faça login para validar se sua conta tem permissão de administrador.</p>

        <form id="adminLoginForm" class="d-grid gap-3">
            <div>
                <label class="form-label" for="adminUsuario">Usuário</label>
                <input id="adminUsuario" class="form-control" required maxlength="100" />
            </div>
            <div>
                <label class="form-label" for="adminSenha">Senha</label>
                <input id="adminSenha" type="password" class="form-control" required maxlength="100" />
            </div>
            <button class="btn btn-primary" type="submit">Entrar no painel</button>
        </form>

        <p id="adminMensagem" class="mt-3 mb-0"></p>
    </div>

    <div id="adminPainel" class="d-none">
        <div class="d-flex justify-content-between align-items-center mb-3 gap-2 flex-wrap">
            <h2 class="mb-0">Painel administrativo</h2>
            <button id="adminSair" class="btn btn-outline-secondary btn-sm" type="button">Sair</button>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-lg-5">
                <div class="glass-card h-100">
                    <h5 class="mb-3">Novo serviço</h5>
                    <form id="novoServicoForm" class="d-grid gap-3">
                        <div>
                            <label class="form-label" for="servicoNome">Nome</label>
                            <input id="servicoNome" class="form-control" maxlength="100" required />
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label" for="servicoDuracao">Duração (min)</label>
                                <input id="servicoDuracao" type="number" min="10" step="5" class="form-control" value="30" required />
                            </div>
                            <div class="col-6">
                                <label class="form-label" for="servicoValor">Valor (R$)</label>
                                <input id="servicoValor" type="number" min="1" step="0.5" class="form-control" required />
                            </div>
                        </div>
                        <div>
                            <label class="form-label" for="servicoDescricao">Descrição</label>
                            <textarea id="servicoDescricao" class="form-control" rows="2" maxlength="300"></textarea>
                        </div>
                        <button class="btn btn-primary" type="submit">Cadastrar serviço</button>
                    </form>
                    <p id="adminServicoMensagem" class="mt-3 mb-0"></p>
                </div>
            </div>

            <div class="col-12 col-lg-7">
                <div class="glass-card h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3 gap-2 flex-wrap">
                        <h5 class="mb-0">Serviços cadastrados</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-dark table-hover align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Serviço</th>
                                <th>Duração</th>
                                <th>Valor</th>
                                <th>Status</th>
                            </tr>
                            </thead>
                            <tbody id="adminServicosBody">
                            <tr><td colspan="4" class="text-muted">Carregando...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="glass-card">
                    <div class="d-flex justify-content-between align-items-center mb-3 gap-2 flex-wrap">
                        <h5 class="mb-0">Agenda do dia</h5>
                        <input id="filtroDataAgenda" type="date" class="form-control form-control-sm admin-date-filter" />
                    </div>
                    <div class="table-responsive">
                        <table class="table table-dark table-striped align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Horário</th>
                                <th>Cliente</th>
                                <th>Telefone</th>
                                <th>Serviço</th>
                                <th>Status</th>
                            </tr>
                            </thead>
                            <tbody id="adminAgendaBody">
                            <tr><td colspan="5" class="text-muted">Selecione uma data para carregar os agendamentos.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <p class="mb-0 text-muted">Acesso administrativo validado com sucesso.</p>
    </div>
</section>

@section Scripts
{
    <script src="~/js/core/cookies.js" asp-append-version="true"></script>
    <script src="~/js/core/requester.js" asp-append-version="true"></script>
    <script src="~/js/services/usuarioService.js" asp-append-version="true"></script>
    <script src="~/js/services/agendamentoService.js" asp-append-version="true"></script>
    <script src="~/js/pages/admin.js" asp-append-version="true"></script>
}

