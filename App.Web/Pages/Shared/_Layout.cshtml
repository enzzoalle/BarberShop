<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - BarberShop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet">
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="icon" type="image/x-icon" href="~/images/favicon.ico" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg navbar-dark navbar-modern">
        <div class="container">
            <a class="navbar-brand navbar-brand-modern" asp-area="" asp-page="/Index">
                <img src="~/images/logo-sphinx.png" asp-append-version="true" alt="Ícone BarberShop" class="navbar-brand-icon"/>
                <span>BarberShop</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse justify-content-between">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-page="/Index">Início</a>
                    </li>
                    <li class="nav-item d-none" id="navPainelAdminItem">
                        <a class="nav-link" id="navPainelAdminLink" asp-area="" asp-page="/Admin/Index">Painel Admin</a>
                    </li>
                </ul>

                <div class="d-flex align-items-center gap-2 mt-3 mt-lg-0" id="authActions">
                    <span id="authWelcome" class="text-light small d-none"></span>
                    <a class="btn btn-outline-light" id="btnEntrar" asp-area="" asp-page="/Entrar">Entrar</a>
                    <a class="btn btn-primary" asp-area="" asp-page="/Agendar">Agendar</a>
                    <button class="btn btn-outline-light d-none" id="btnSair" type="button">Sair</button>
                </div>
            </div>
        </div>
    </nav>
</header>
<main role="main" class="pb-4">
    @RenderBody()
</main>

<footer class="footer text-light">
    <div class="container">
        &copy; 2026 - BarberShop
    </div>
</footer>

<script>
        window.APP_CONFIG = {
            apiBase: '@(Context.Request.Scheme + "://" + Context.Request.Host + "/")'
        };
    </script>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/core/functions.js" asp-append-version="true"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>